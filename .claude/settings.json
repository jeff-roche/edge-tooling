{
  "permissions": {
    "allow": [
      "Bash(cd payload-monitor *)",
      "Bash(python3 -m venv *)",
      "Bash(payload-monitor/.venv/bin/pip install *)",
      "Bash(payload-monitor/.venv/bin/python *)",
      "Bash(gsutil cat *)",
      "Bash(gsutil ls *)",
      "Bash(gcloud storage ls *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/update-submodules.sh",
            "timeout": 30,
            "statusMessage": "Checking for submodule updates..."
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/detect-new-tools.sh",
            "timeout": 10,
            "statusMessage": "Checking for new tool directories..."
          }
        ]
      }
    ]
  }
}

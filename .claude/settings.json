{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/detect-new-tools.sh",
            "timeout": 10,
            "statusMessage": "Checking for new tool directories..."
          }
        ]
      }
    ]
  }
}

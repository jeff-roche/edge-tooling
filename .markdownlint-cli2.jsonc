{
  "config": {
    "default": true,
    "MD013": false,
    "MD034": false,
    "MD060": { "style": "consistent" }
  },
  "outputFormatters": [
    [ "markdownlint-cli2-formatter-pretty", { "appendLink": true } ],
    [ "markdownlint-cli2-formatter-junit" ],
    [ "markdownlint-cli2-formatter-json" ]
  ],
  "ignores": [
    "node_modules/**",
    "two-node-toolbox/**"
  ]
}

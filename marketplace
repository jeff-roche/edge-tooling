#!/usr/bin/env bash
#
# Plugin Marketplace CLI
# Manage Claude Code plugins for OpenShift and edge workflows
#

set -euo pipefail

# Constants
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGINS_DIR="${SCRIPT_DIR}/plugins"
REGISTRY_DIR="${PLUGINS_DIR}/.registry"
CATALOG_FILE="${REGISTRY_DIR}/catalog.yml"
STATE_FILE="${REGISTRY_DIR}/state.yml"
SCHEMA_FILE="${REGISTRY_DIR}/schema.yml"
TEMPLATES_DIR="${PLUGINS_DIR}/.templates"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# Helper functions
error() {
    echo -e "${RED}Error:${NC} $*" >&2
    exit 1
}

warn() {
    echo -e "${YELLOW}Warning:${NC} $*" >&2
}

info() {
    echo -e "${BLUE}Info:${NC} $*"
}

success() {
    echo -e "${GREEN}Success:${NC} $*"
}

# Check dependencies
check_dependencies() {
    local deps=("yq" "git" "python3")
    local missing=()

    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &> /dev/null; then
            missing+=("$dep")
        fi
    done

    if [ ${#missing[@]} -gt 0 ]; then
        error "Missing required dependencies: ${missing[*]}\nInstall with: dnf install yq git python3"
    fi
}

# Parse YAML using yq
yaml_get() {
    local file="$1"
    local query="$2"
    yq eval "$query" "$file" 2>/dev/null || echo ""
}

# Check if a plugin is installed
is_installed() {
    local name="$1"
    local check
    check=$(yq eval ".installed_plugins[] | select(.name == \"$name\") | .name" "$STATE_FILE" 2>/dev/null)
    [[ -n "$check" && "$check" != "null" ]]
}

# Update catalog from plugins directory
update_catalog() {
    info "Scanning plugins directory..."

    local plugin_count=0

    # Write initial catalog structure
    cat > "$CATALOG_FILE" <<EOF
# Plugin Marketplace Catalog
# Auto-generated - do not edit manually
# Last updated: $(date -u +"%Y-%m-%dT%H:%M:%SZ")

version: "1.0"
plugins: []
EOF

    # Find all plugin directories (contain plugin.yml)
    while IFS= read -r -d '' plugin_file; do
        local plugin_dir=$(dirname "$plugin_file")
        local plugin_name=$(basename "$plugin_dir")

        # Skip template and registry directories
        [[ "$plugin_name" == ".templates" || "$plugin_name" == ".registry" || "$plugin_name" == "docs" ]] && continue

        # Extract metadata
        local name=$(yaml_get "$plugin_file" ".name")
        local version=$(yaml_get "$plugin_file" ".version")
        local type=$(yaml_get "$plugin_file" ".type")
        local category=$(yaml_get "$plugin_file" ".category")
        local description=$(yaml_get "$plugin_file" ".description")
        local author=$(yaml_get "$plugin_file" ".author")

        # Validate required fields
        if [[ -z "$name" || -z "$version" || -z "$type" || -z "$category" ]]; then
            warn "Skipping $plugin_name: missing required metadata fields"
            continue
        fi

        # Add to catalog using yq with env vars for safe YAML generation
        NAME="$name" VERSION="$version" TYPE="$type" CATEGORY="$category" \
            DESCRIPTION="$description" AUTHOR="$author" PLUGIN_PATH="$plugin_name" \
            yq eval -i '.plugins += [{"name": env(NAME), "version": env(VERSION), "type": env(TYPE), "category": env(CATEGORY), "description": env(DESCRIPTION), "author": env(AUTHOR), "path": env(PLUGIN_PATH)}]' "$CATALOG_FILE"

        ((plugin_count++)) || true
    done < <(find "$PLUGINS_DIR" -maxdepth 2 -name "plugin.yml" -print0)

    success "Catalog updated: $plugin_count plugins found"
}

# List all available plugins
list_plugins() {
    local filter="$1"

    # Update catalog first
    update_catalog

    echo -e "${BOLD}Available Plugins:${NC}\n"

    local count=0
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue

        local version=$(yq eval ".plugins[] | select(.name == \"$name\") | .version" "$CATALOG_FILE")
        local type=$(yq eval ".plugins[] | select(.name == \"$name\") | .type" "$CATALOG_FILE")
        local category=$(yq eval ".plugins[] | select(.name == \"$name\") | .category" "$CATALOG_FILE")
        local description=$(yq eval ".plugins[] | select(.name == \"$name\") | .description" "$CATALOG_FILE")
        local author=$(yq eval ".plugins[] | select(.name == \"$name\") | .author" "$CATALOG_FILE")

        # Apply filter if provided
        if [[ -n "$filter" ]]; then
            if [[ ! "$name" =~ $filter && ! "$category" =~ $filter && ! "$description" =~ $filter ]]; then
                continue
            fi
        fi

        # Check if installed
        local installed=""
        if is_installed "$name"; then
            installed=" ${GREEN}[installed]${NC}"
        fi

        echo -e "${CYAN}${name}${NC} ${MAGENTA}(v${version})${NC}${installed}"
        echo -e "  ${BOLD}Type:${NC} $type | ${BOLD}Category:${NC} $category | ${BOLD}Author:${NC} $author"
        echo -e "  $description"
        echo ""

        ((count++)) || true
    done < <(yq eval '.plugins[].name' "$CATALOG_FILE")

    if [ $count -eq 0 ]; then
        warn "No plugins found matching filter: $filter"
    else
        echo -e "${BOLD}Total:${NC} $count plugins"
    fi
}

# Show plugin details
show_plugin() {
    local plugin_name="$1"

    local plugin_path=$(yq eval ".plugins[] | select(.name == \"$plugin_name\") | .path" "$CATALOG_FILE")
    if [[ -z "$plugin_path" || "$plugin_path" == "null" ]]; then
        error "Plugin not found: $plugin_name"
    fi

    local plugin_file="${PLUGINS_DIR}/${plugin_path}/plugin.yml"
    if [[ ! -f "$plugin_file" ]]; then
        error "Plugin metadata not found: $plugin_file"
    fi

    echo -e "${BOLD}Plugin Details: ${CYAN}${plugin_name}${NC}\n"

    # Basic info
    local version=$(yaml_get "$plugin_file" ".version")
    local type=$(yaml_get "$plugin_file" ".type")
    local category=$(yaml_get "$plugin_file" ".category")
    local author=$(yaml_get "$plugin_file" ".author")
    local description=$(yaml_get "$plugin_file" ".description")
    local long_desc=$(yaml_get "$plugin_file" ".long_description")

    echo -e "${BOLD}Version:${NC} $version"
    echo -e "${BOLD}Type:${NC} $type"
    echo -e "${BOLD}Category:${NC} $category"
    echo -e "${BOLD}Author:${NC} $author"
    echo -e "${BOLD}Description:${NC} $description"

    if [[ -n "$long_desc" && "$long_desc" != "null" ]]; then
        echo -e "\n${BOLD}Details:${NC}\n$long_desc"
    fi

    # Compatibility
    echo -e "\n${BOLD}Compatibility:${NC}"
    local min_version=$(yaml_get "$plugin_file" ".compatibility.claude_code_min")
    [[ -n "$min_version" && "$min_version" != "null" ]] && echo "  Claude Code: >= $min_version"

    local ocp_versions=$(yaml_get "$plugin_file" ".compatibility.openshift_versions[]")
    [[ -n "$ocp_versions" && "$ocp_versions" != "null" ]] && echo "  OpenShift: $ocp_versions"

    local required_tools=$(yaml_get "$plugin_file" ".compatibility.required_tools[]")
    [[ -n "$required_tools" && "$required_tools" != "null" ]] && echo "  Required tools: $required_tools"

    # Dependencies
    local deps=$(yaml_get "$plugin_file" ".dependencies.plugins[]")
    if [[ -n "$deps" && "$deps" != "null" ]]; then
        echo -e "\n${BOLD}Dependencies:${NC}"
        echo "  $deps"
    fi

    # Usage examples
    local examples=$(yaml_get "$plugin_file" ".usage.examples[]")
    if [[ -n "$examples" && "$examples" != "null" ]]; then
        echo -e "\n${BOLD}Examples:${NC}"
        while IFS= read -r example; do
            echo "  - $example"
        done <<< "$examples"
    fi

    # Installation status
    echo -e "\n${BOLD}Status:${NC}"
    if is_installed "$plugin_name"; then
        local install_date=$(yq eval ".installed_plugins[] | select(.name == \"$plugin_name\") | .install_date" "$STATE_FILE")
        echo -e "  ${GREEN}Installed${NC} (on $install_date)"
    else
        echo "  Not installed"
    fi

    # Show README if available
    local readme="${PLUGINS_DIR}/${plugin_path}/README.md"
    if [[ -f "$readme" ]]; then
        echo -e "\n${BOLD}Documentation:${NC}"
        echo "  See: plugins/${plugin_path}/README.md"
    fi
}

# Install a plugin
install_plugin() {
    local plugin_name="$1"
    local force="${2:-false}"

    info "Installing plugin: $plugin_name"

    # Check if already installed
    if is_installed "$plugin_name"; then
        if [[ "$force" != "true" ]]; then
            warn "Plugin already installed. Use --force to reinstall."
            return 0
        fi
        info "Reinstalling plugin..."
    fi

    # Get plugin path
    local plugin_path=$(yq eval ".plugins[] | select(.name == \"$plugin_name\") | .path" "$CATALOG_FILE")
    if [[ -z "$plugin_path" || "$plugin_path" == "null" ]]; then
        error "Plugin not found in catalog: $plugin_name"
    fi

    local plugin_file="${PLUGINS_DIR}/${plugin_path}/plugin.yml"
    if [[ ! -f "$plugin_file" ]]; then
        error "Plugin metadata not found: $plugin_file"
    fi

    # Validate plugin
    validate_plugin "$plugin_name"

    # Check dependencies
    local deps=$(yaml_get "$plugin_file" ".dependencies.plugins[]")
    if [[ -n "$deps" && "$deps" != "null" ]]; then
        info "Checking dependencies..."
        while IFS= read -r dep; do
            if ! is_installed "$dep"; then
                warn "Missing dependency: $dep"
                read -p "Install dependency $dep? (y/n) " -n 1 -r
                echo
                if [[ $REPLY =~ ^[Yy]$ ]]; then
                    install_plugin "$dep"
                else
                    error "Cannot install $plugin_name without dependency $dep"
                fi
            fi
        done <<< "$deps"
    fi

    # Determine Claude Code config directory
    local claude_dir="${HOME}/.claude"
    if [[ ! -d "$claude_dir" ]]; then
        warn "Claude Code config directory not found: $claude_dir"
        read -p "Create it? (y/n) " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            mkdir -p "$claude_dir"
        else
            error "Installation cancelled"
        fi
    fi

    # Install files based on plugin type
    local type=$(yaml_get "$plugin_file" ".type")
    local version=$(yaml_get "$plugin_file" ".version")

    case "$type" in
        skill)
            info "Installing skill files..."
            local skills_dir="${claude_dir}/skills"
            mkdir -p "$skills_dir"

            local skills=$(yaml_get "$plugin_file" ".install.skills[]")
            if [[ -n "$skills" && "$skills" != "null" ]]; then
                while IFS= read -r skill_file; do
                    local src="${PLUGINS_DIR}/${plugin_path}/${skill_file}"
                    local dst="${skills_dir}/${plugin_name}-$(basename "$skill_file")"
                    if [[ -f "$src" ]]; then
                        cp "$src" "$dst"
                        info "  Installed: $dst"
                    else
                        warn "  Skill file not found: $src"
                    fi
                done <<< "$skills"
            fi
            ;;
        command)
            info "Installing command files..."
            local commands_dir="${claude_dir}/commands"
            mkdir -p "$commands_dir"

            local commands=$(yaml_get "$plugin_file" ".install.commands[]")
            if [[ -n "$commands" && "$commands" != "null" ]]; then
                while IFS= read -r cmd_file; do
                    local src="${PLUGINS_DIR}/${plugin_path}/${cmd_file}"
                    local dst="${commands_dir}/$(basename "$cmd_file")"
                    if [[ -f "$src" ]]; then
                        cp "$src" "$dst"
                        chmod +x "$dst"
                        info "  Installed: $dst"
                    else
                        warn "  Command file not found: $src"
                    fi
                done <<< "$commands"
            fi
            ;;
        subagent)
            info "Installing agent files..."
            local agents_dir="${claude_dir}/agents"
            mkdir -p "$agents_dir"

            local agents
            agents=$(yaml_get "$plugin_file" ".install.agents[]")
            if [[ -n "$agents" && "$agents" != "null" ]]; then
                while IFS= read -r agent_file; do
                    local src="${PLUGINS_DIR}/${plugin_path}/${agent_file}"
                    local dst="${agents_dir}/${plugin_name}-$(basename "$agent_file")"
                    if [[ -f "$src" ]]; then
                        cp "$src" "$dst"
                        info "  Installed: $dst"
                    else
                        warn "  Agent file not found: $src"
                    fi
                done <<< "$agents"
            else
                warn "No agent files specified in install.agents for plugin $plugin_name"
            fi
            ;;
        hybrid)
            warn "hybrid plugin type: install steps are implementation-defined. Check plugin.yml for manual instructions."
            ;;
        *)
            warn "Plugin type '$type' installation not fully implemented yet"
            ;;
    esac

    # Warn about install keys that are declared but not processed
    local has_files has_hooks
    has_files=$(yaml_get "$plugin_file" ".install.files | length")
    has_hooks=$(yaml_get "$plugin_file" ".install.hooks | length")
    if [[ "${has_files:-0}" -gt 0 ]] 2>/dev/null; then
        warn "install.files declared in plugin.yml but not processed — manual installation required"
    fi
    if [[ "${has_hooks:-0}" -gt 0 ]] 2>/dev/null; then
        warn "install.hooks declared in plugin.yml but not processed — manual hook registration required"
    fi

    # Run post-install script if present
    local post_install=$(yaml_get "$plugin_file" ".install.post_install")
    if [[ -n "$post_install" && "$post_install" != "null" ]]; then
        local post_script="${PLUGINS_DIR}/${plugin_path}/${post_install}"
        if [[ -f "$post_script" ]]; then
            info "Running post-install script..."
            bash "$post_script" || warn "Post-install script failed"
        fi
    fi

    # Update state file
    local install_date=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # Remove existing entry if reinstalling
    yq eval -i "del(.installed_plugins[] | select(.name == \"$plugin_name\"))" "$STATE_FILE"

    # Add new entry
    yq eval -i ".installed_plugins += [{\"name\": \"$plugin_name\", \"version\": \"$version\", \"install_date\": \"$install_date\", \"status\": \"active\"}]" "$STATE_FILE"

    success "Plugin installed: $plugin_name"

    # Show usage info
    local examples=$(yaml_get "$plugin_file" ".usage.examples[]")
    if [[ -n "$examples" && "$examples" != "null" ]]; then
        echo -e "\n${BOLD}Usage Examples:${NC}"
        while IFS= read -r example; do
            echo "  - $example"
        done <<< "$examples"
    fi
}

# Uninstall a plugin
uninstall_plugin() {
    local plugin_name="$1"

    info "Uninstalling plugin: $plugin_name"

    # Check if installed
    if ! is_installed "$plugin_name"; then
        warn "Plugin not installed: $plugin_name"
        return 0
    fi

    # Get plugin info
    local plugin_path=$(yq eval ".plugins[] | select(.name == \"$plugin_name\") | .path" "$CATALOG_FILE")
    local plugin_file="${PLUGINS_DIR}/${plugin_path}/plugin.yml"

    # Remove installed files
    local claude_dir="${HOME}/.claude"
    local type=$(yaml_get "$plugin_file" ".type")

    case "$type" in
        skill)
            local skills_dir="${claude_dir}/skills"
            find "$skills_dir" -maxdepth 1 -name "${plugin_name}-*" -delete 2>/dev/null || true
            ;;
        command)
            local commands_dir="${claude_dir}/commands"
            local commands=$(yaml_get "$plugin_file" ".install.commands[]")
            if [[ -n "$commands" && "$commands" != "null" ]]; then
                while IFS= read -r cmd_file; do
                    rm -f "${commands_dir}/$(basename "$cmd_file")"
                done <<< "$commands"
            fi
            ;;
        subagent)
            local agents_dir="${claude_dir}/agents"
            find "$agents_dir" -maxdepth 1 -name "${plugin_name}-*" -delete 2>/dev/null || true
            ;;
    esac

    # Update state file
    yq eval -i "del(.installed_plugins[] | select(.name == \"$plugin_name\"))" "$STATE_FILE"

    success "Plugin uninstalled: $plugin_name"
}

# Validate plugin metadata
validate_plugin() {
    local plugin_name="$1"

    # Refresh catalog so validation always reflects current plugin state
    update_catalog

    local plugin_path=$(yq eval ".plugins[] | select(.name == \"$plugin_name\") | .path" "$CATALOG_FILE")
    if [[ -z "$plugin_path" || "$plugin_path" == "null" ]]; then
        error "Plugin not found: $plugin_name"
    fi

    local plugin_file="${PLUGINS_DIR}/${plugin_path}/plugin.yml"
    local plugin_dir="${PLUGINS_DIR}/${plugin_path}"

    info "Validating plugin: $plugin_name"

    local errors=0

    # Check required files
    if [[ ! -f "$plugin_file" ]]; then
        error "Missing plugin.yml"
    fi

    if [[ ! -f "${plugin_dir}/README.md" ]]; then
        warn "Missing README.md"
        ((errors++)) || true
    fi

    # Validate required fields
    local required_fields=("name" "version" "type" "category" "description" "author")
    for field in "${required_fields[@]}"; do
        local value=$(yaml_get "$plugin_file" ".$field")
        if [[ -z "$value" || "$value" == "null" ]]; then
            warn "Missing required field: $field"
            ((errors++)) || true
        fi
    done

    # Validate type
    local type=$(yaml_get "$plugin_file" ".type")
    if [[ ! "$type" =~ ^(skill|command|subagent|hybrid)$ ]]; then
        warn "Invalid type: $type (must be skill|command|subagent|hybrid)"
        ((errors++)) || true
    fi

    # Validate category
    local category=$(yaml_get "$plugin_file" ".category")
    if [[ ! "$category" =~ ^(cluster-ops|debug|deploy|network|operator|ci-cd|util)$ ]]; then
        warn "Invalid category: $category"
        ((errors++)) || true
    fi

    # Validate version format (semver)
    local version=$(yaml_get "$plugin_file" ".version")
    if [[ ! "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        warn "Invalid version format: $version (expected semver: X.Y.Z)"
        ((errors++)) || true
    fi

    if [ $errors -eq 0 ]; then
        success "Validation passed"
        return 0
    else
        warn "Validation completed with $errors warnings"
        return 1
    fi
}

# Show status of installed plugins
show_status() {
    echo -e "${BOLD}Installed Plugins:${NC}\n"

    local count=0
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue

        local version=$(yq eval ".installed_plugins[] | select(.name == \"$name\") | .version" "$STATE_FILE")
        local install_date=$(yq eval ".installed_plugins[] | select(.name == \"$name\") | .install_date" "$STATE_FILE")
        local status=$(yq eval ".installed_plugins[] | select(.name == \"$name\") | .status" "$STATE_FILE")

        # Check if update available
        local latest_version=$(yq eval ".plugins[] | select(.name == \"$name\") | .version" "$CATALOG_FILE")
        local update_indicator=""
        if [[ "$version" != "$latest_version" ]]; then
            update_indicator=" ${YELLOW}(update available: v${latest_version})${NC}"
        fi

        echo -e "${CYAN}${name}${NC} ${MAGENTA}(v${version})${NC}${update_indicator}"
        echo -e "  Installed: $install_date | Status: $status"
        echo ""

        ((count++)) || true
    done < <(yq eval '.installed_plugins[].name' "$STATE_FILE")

    if [ $count -eq 0 ]; then
        info "No plugins installed"
    else
        echo -e "${BOLD}Total:${NC} $count plugins installed"
    fi
}

# Helper: copy a template file to a destination, substituting known placeholders.
# Only safe/validated values (name, category, type, date) are substituted here.
# Usage: _scaffold_from_template <src> <dst> <plugin_name> <category> [type]
_scaffold_from_template() {
    local src="$1"
    local dst="$2"
    local plugin_name="$3"
    local category="$4"
    local type="${5:-}"
    local today
    today="$(date -u +"%Y-%m-%d")"
    sed \
        -e "s/{{PLUGIN_NAME}}/${plugin_name}/g" \
        -e "s/{{CATEGORY}}/${category}/g" \
        -e "s/{{TYPE}}/${type}/g" \
        -e "s/{{DATE}}/${today}/g" \
        "$src" > "$dst"
}

# Create new plugin from template
create_plugin() {
    local plugin_name="$1"

    # Validate name
    if [[ ! "$plugin_name" =~ ^[a-z][a-z0-9-]*$ ]]; then
        error "Invalid plugin name. Must start with a letter; use only lowercase letters, numbers, and hyphens."
    fi

    # Check if already exists
    if [[ -d "${PLUGINS_DIR}/${plugin_name}" ]]; then
        error "Plugin directory already exists: ${plugin_name}"
    fi

    echo -e "${BOLD}Creating new plugin: ${CYAN}${plugin_name}${NC}\n"

    # Interactive prompts
    read -p "Plugin type (skill/command/subagent/hybrid): " type
    [[ ! "$type" =~ ^(skill|command|subagent|hybrid)$ ]] && error "Invalid type"

    read -p "Category (cluster-ops/debug/deploy/network/operator/ci-cd/util): " category
    [[ ! "$category" =~ ^(cluster-ops|debug|deploy|network|operator|ci-cd|util)$ ]] && error "Invalid category"

    read -p "Short description: " description
    read -p "Author (your GitHub handle): " author

    local plugin_dir="${PLUGINS_DIR}/${plugin_name}"

    # Resolve the templates directory for this plugin type.
    # hybrid falls back to the subagent templates (basic structure only).
    local templates_type="$type"
    [[ "$type" == "hybrid" ]] && templates_type="subagent"
    local templates_dir="${TEMPLATES_DIR}/${templates_type}"

    if [[ ! -d "$templates_dir" ]]; then
        error "Templates directory not found: ${templates_dir}"
    fi

    local required_templates=("plugin.yml.template" "README.md.template")
    case "$type" in
        skill)    required_templates+=("skill.md.template") ;;
        command)  required_templates+=("command.sh.template") ;;
        subagent) required_templates+=("agent.md.template") ;;
        hybrid)
            warn "hybrid type uses basic scaffolding — custom implementation required."
            required_templates+=("agent.md.template")
            ;;
    esac
    for tmpl in "${required_templates[@]}"; do
        [[ -f "${templates_dir}/${tmpl}" ]] || error "Template file not found: ${templates_dir}/${tmpl}"
    done

    # All pre-flight checks passed — create the directory now.
    # The trap ensures cleanup if anything fails from this point on.
    trap 'rm -rf "$plugin_dir"' ERR
    mkdir -p "$plugin_dir"

    # plugin.yml: substitute safe fields via sed, then inject user-supplied
    # description and author through yq to avoid YAML injection.
    _scaffold_from_template "${templates_dir}/plugin.yml.template" "${plugin_dir}/plugin.yml" "$plugin_name" "$category" "$type"
    DESCRIPTION="$description" AUTHOR="$author" \
        yq eval -i '.description = env(DESCRIPTION) | .author = env(AUTHOR)' "${plugin_dir}/plugin.yml"

    # Type-specific file
    case "$type" in
        skill)
            _scaffold_from_template "${templates_dir}/skill.md.template" "${plugin_dir}/skill.md" "$plugin_name" "$category"
            ;;
        command)
            _scaffold_from_template "${templates_dir}/command.sh.template" "${plugin_dir}/command.sh" "$plugin_name" "$category"
            chmod +x "${plugin_dir}/command.sh"
            ;;
        subagent|hybrid)
            _scaffold_from_template "${templates_dir}/agent.md.template" "${plugin_dir}/agent.md" "$plugin_name" "$category"
            ;;
    esac

    # README.md: single-pass substitution via python3 to handle all four
    # placeholders atomically, including free-form user input (description, author).
    (python3 - "${templates_dir}/README.md.template" "${plugin_dir}/README.md" \
        "$plugin_name" "$category" "$description" "$author" <<'PYEOF'
import sys
tmpl, dst, name, cat, desc, author = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5], sys.argv[6]
content = open(tmpl, encoding='utf-8').read()
for placeholder, value in [('{{PLUGIN_NAME}}', name), ('{{CATEGORY}}', cat),
                            ('{{DESCRIPTION}}', desc), ('{{AUTHOR}}', author)]:
    content = content.replace(placeholder, value)
open(dst, 'w', encoding='utf-8').write(content)
PYEOF
    ) || error "Failed to generate README.md from template"

    trap - ERR

    success "Plugin scaffolding created: ${plugin_dir}"
    echo -e "\nNext steps:"
    echo "  1. Edit ${plugin_dir}/plugin.yml to complete metadata"
    echo "  2. Implement your skill/command"
    echo "  3. Fill in <!-- TODO: --> markers in README.md and agent.md"
    echo "  4. Test with: ./marketplace validate ${plugin_name}"
    echo "  5. Install with: ./marketplace install ${plugin_name}"
}

# Main CLI handler
main() {
    # Ensure directories exist
    mkdir -p "$REGISTRY_DIR"

    # Initialize state file if missing
    if [[ ! -f "$STATE_FILE" ]]; then
        cat > "$STATE_FILE" <<EOF
version: "1.0"
installed_plugins: []
last_update_check: null
EOF
    fi

    # Check dependencies
    check_dependencies

    # Parse command
    local command="${1:-help}"
    shift || true

    case "$command" in
        list|ls)
            list_plugins "${1:-}"
            ;;
        show|info)
            [[ -z "${1:-}" ]] && error "Usage: marketplace show <plugin-name>"
            show_plugin "$1"
            ;;
        search)
            [[ -z "${1:-}" ]] && error "Usage: marketplace search <query>"
            list_plugins "$1"
            ;;
        install)
            [[ -z "${1:-}" ]] && error "Usage: marketplace install <plugin-name> [--force]"
            local force_flag="false"
            [[ "${2:-}" == "--force" ]] && force_flag="true"
            install_plugin "$1" "$force_flag"
            ;;
        uninstall|remove)
            [[ -z "${1:-}" ]] && error "Usage: marketplace uninstall <plugin-name>"
            uninstall_plugin "$1"
            ;;
        update)
            if [[ -n "${1:-}" ]]; then
                info "Updating plugin: $1"
                install_plugin "$1" "true"
            else
                info "Updating all installed plugins..."
                while IFS= read -r name; do
                    [[ -z "$name" ]] && continue
                    install_plugin "$name" "true"
                done < <(yq eval '.installed_plugins[].name' "$STATE_FILE")
            fi
            ;;
        validate)
            [[ -z "${1:-}" ]] && error "Usage: marketplace validate <plugin-name>"
            validate_plugin "$1"
            ;;
        status)
            show_status
            ;;
        new|create)
            [[ -z "${1:-}" ]] && error "Usage: marketplace new <plugin-name>"
            create_plugin "$1"
            ;;
        catalog-update)
            update_catalog
            ;;
        help|--help|-h)
            cat <<EOF
${BOLD}Plugin Marketplace CLI${NC}

${BOLD}Usage:${NC}
  marketplace <command> [arguments]

${BOLD}Commands:${NC}
  ${CYAN}list${NC} [filter]              List all available plugins (optionally filtered)
  ${CYAN}search${NC} <query>             Search plugins by name, category, or description
  ${CYAN}show${NC} <plugin>              Show detailed information about a plugin
  ${CYAN}install${NC} <plugin> [--force] Install a plugin
  ${CYAN}uninstall${NC} <plugin>         Uninstall a plugin
  ${CYAN}update${NC} [plugin]            Update plugin(s) to latest version
  ${CYAN}status${NC}                     Show installed plugins and check for updates
  ${CYAN}validate${NC} <plugin>          Validate plugin metadata
  ${CYAN}new${NC} <name>                 Create new plugin from template
  ${CYAN}catalog-update${NC}             Rebuild catalog from plugins directory
  ${CYAN}help${NC}                       Show this help message

${BOLD}Examples:${NC}
  marketplace list                    # List all plugins
  marketplace search network          # Search for network plugins
  marketplace show ovn-topology       # Show plugin details
  marketplace install ovn-topology    # Install a plugin
  marketplace update                  # Update all plugins
  marketplace new my-plugin           # Create new plugin

${BOLD}Documentation:${NC}
  Plugin development: plugins/docs/DEVELOPMENT.md
  Contributing:       plugins/docs/CONTRIBUTING.md
  Plugin structure:   plugins/README.md

${BOLD}Support:${NC}
  Report issues at: https://github.com/openshift-eng/edge-tooling/issues
EOF
            ;;
        *)
            error "Unknown command: $command\nRun 'marketplace help' for usage information"
            ;;
    esac
}

# Run main
main "$@"
